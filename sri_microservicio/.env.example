# ===== Django =====
SECRET_KEY=cambia-esto-por-una-clave-larga-y-secreta
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ===== Celery / Redis =====
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ===== Emisor / SRI =====
SRI_SIMULADO=True                    # True = sin firma real ni conexión al SRI (dev)
SRI_AMBIENTE=1                       # 1=Pruebas, 2=Producción
SRI_TIPO_EMISION=1                   # 1=Normal
EMISOR_RUC=1790012345001
EMISOR_RAZON_SOCIAL=MI EMPRESA S.A.
EMISOR_NOMBRE_COMERCIAL=Mi Tienda
EMISOR_DIR_MATRIZ=Av. Siempre Viva 123
EMISOR_DIR_ESTABLECIMIENTO=Av. Siempre Viva 123
EMISOR_ESTABLECIMIENTO=001
EMISOR_PUNTO_EMISION=001
EMISOR_OBLIGADO_CONTABILIDAD=NO
EMISOR_CONTRIBUYENTE_ESPECIAL=

# ===== Firma digital (.p12) =====
FIRMA_P12_PATH=/ruta/segura/firma.p12
FIRMA_P12_PASSWORD=clave-del-certificado

# ===== WSDL SRI (Pruebas) =====
SRI_WSDL_RECEPCION=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline?wsdl
SRI_WSDL_AUTORIZACION=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline?wsdl

# ===== Correo (SMTP) =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=facturacion@miempresa.com
EMAIL_HOST_PASSWORD=app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Facturación <facturacion@miempresa.com>

# ===== Almacenamiento de comprobantes =====
COMPROBANTES_DIR=comprobantes
