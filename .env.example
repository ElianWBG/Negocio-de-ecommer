# Copia este archivo como ".env" (sin .example) y rellena tus valores reales.
# El archivo ".env" NUNCA se sube a GitHub (ya está en .gitignore).

# Genera una clave nueva con:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1

# Conexión a Postgres. Formato:
# postgres://usuario:password@host:puerto/nombre_basededatos
#
# Para tu Postgres LOCAL (ajusta usuario/password al que configuraste al instalarlo):
DATABASE_URL=postgres://postgres:tu_password@localhost:5432/sales_a2

# Solo se usa en producción, cuando tengas un dominio real (ej: midominio.com).
# En local déjalo vacío.
CSRF_TRUSTED_ORIGINS=

# Credenciales de PayPhone (Payphone Developer > tu app tipo "WEB").
# Mientras no las llenes, el botón de "pagar con tarjeta" mostrará un
# error, pero el resto del sitio funciona igual.
PAYPHONE_TOKEN=
PAYPHONE_STORE_ID=

# Email — en local déjalo en 'console' para ver los emails en la terminal.
# En producción usa 'django.core.mail.backends.smtp.EmailBackend' y llena el resto.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@mitienda.com

# Correo del proveedor que recibe notificación cuando llega un pedido nuevo.
# Déjalo vacío para desactivar.
ADMIN_NOTIFICATION_EMAIL=
